{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["server/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
